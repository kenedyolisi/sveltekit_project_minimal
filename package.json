    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.0",
    "vite-plugin-devtools-json": "^1.0.0"
  }
